{
  "name": "cyberaudit-skill",
  "version": "3.2.0",
  "description": "Universal security audit skill for AI agents. Install once, audit any web or mobile app. OpenCode, Claude Code, Cursor, Kiro, Gemini — all supported.",
  "keywords": [
    "mcp",
    "security",
    "audit",
    "cybersecurity",
    "owasp",
    "pentest",
    "skill",
    "ai-agent",
    "opencode",
    "claude-code",
    "cursor"
  ],
  "author": "ArisRoman",
  "license": "MIT",
  "homepage": "https://github.com/ArisRoman/cyberaudit-skill",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArisRoman/cyberaudit-skill.git"
  },
  "bugs": {
    "url": "https://github.com/ArisRoman/cyberaudit-skill/issues"
  },
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "cyberaudit-skill": "dist/cli.js"
  },
  "files": [
    "dist/",
    "skills/"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "dev:serve": "tsx src/mcp-server.ts",
    "install:local": "node dist/cli.js install",
    "install:all": "node dist/cli.js install --agent all",
    "serve": "node dist/mcp-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
